# Database
DATABASE_URL=""

# Gemini — múltiplas keys e modelos separados por vírgula (sem espaços)
# Ordem de preferência: primeiro modelo é o principal; os demais são fallback.
#
# Modelos premium (suportam thinking_config):
#   gemini-2.5-pro, gemini-2.5-flash, gemini-3-flash-preview
#
# Modelos standard / flash (sem thinking_config):
#   gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-pro, gemini-1.5-flash
#
GEMINI_API_KEY="key1,key2,key3"
GEMINI_MODEL="gemini-2.5-pro,gemini-2.5-flash,gemini-1.5-flash"
